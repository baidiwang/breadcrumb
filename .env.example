# Copy to .env.local for local dev. NEVER commit real keys.

# Option A — local dev (desktop + Vite): call Anthropic directly from the frontend.
# Key stays in .env.local which is gitignored. Safe only for local machines.
VITE_ANTHROPIC_API_KEY=

# Option B — web/Vercel deploy: proxy URL that holds the key server-side.
VITE_AI_PROXY=http://localhost:3000/api/ai

# Server-side only (Vercel project env vars, never exposed to client):
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
