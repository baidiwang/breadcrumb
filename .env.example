# Copy to .env.local for web dev. NEVER commit real keys.
# For the desktop build, prefer storing the key in the OS keychain instead.

# Where the frontend sends AI requests. For local web dev pointing at vercel dev:
VITE_AI_PROXY=http://localhost:3000/api/ai

# Server-side only (Vercel project env, NOT exposed to client):
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
