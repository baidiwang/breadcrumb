# Copy to .env.local for local dev. NEVER commit real keys. .env.local is gitignored by *.local.

# Point the AI client at the Vite dev-server proxy (works for both browser dev and tauri dev).
# The proxy lives in vite.config.ts and calls Anthropic from Node — the key never reaches
# the browser bundle. Use the same value for Vercel; api/ai.ts handles it there.
VITE_AI_PROXY=/api/ai

# Anthropic key — NO VITE_ prefix means Vite will NOT expose this to the browser bundle.
# Vite's configureServer reads it via loadEnv() (Node-only). Never put this in a VITE_ var.
ANTHROPIC_API_KEY=

# For Vercel deploy: set ANTHROPIC_API_KEY in project environment variables (Settings → Env Vars).
# Do not commit real keys here.
